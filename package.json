    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dicom-parser": "^1.8.21",
    "dompurify": "^3.4.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
