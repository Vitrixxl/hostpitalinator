{
  "name": "hospitalinator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "dev": "PUBLIC_API_BASE_URL=http://127.0.0.1:4000 bun --port=5173 ./index.html",
    "api:dev": "cargo run --manifest-path api/Cargo.toml",
    "api:build": "cargo build --manifest-path api/Cargo.toml",
    "api:start": "cargo run --manifest-path api/Cargo.toml",
    "medicines:import": "bun run scripts/import-bdpm.ts",
    "build": "tsc -b && bun run build.ts",
    "lint": "eslint .",
    "preview": "bun --port=4173 ./dist/index.html",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build"
  },
  "dependencies": {
    "@fontsource-variable/merriweather": "^5.2.6",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.9.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
