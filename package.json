{
  "name": "hospitalinator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "dev": "PUBLIC_SKIP_STARTUP_LOADING=true PUBLIC_DEV_DARK_MODE=true PUBLIC_API_BASE_URL=http://127.0.0.1:4000 bun ./index.html --host=127.0.0.1:5173",
    "api:dev": "cargo run --manifest-path api/Cargo.toml",
    "api:build": "cargo build --manifest-path api/Cargo.toml",
    "api:start": "cargo run --manifest-path api/Cargo.toml",
    "medicines:import": "bun run scripts/import-bdpm.ts",
    "doctors:import": "bun run scripts/import-ans-doctors.ts",
    "build": "tsc -b && bun run build.ts",
    "lint": "eslint .",
    "preview": "bun --port=4173 ./dist/index.html",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build"
  },
  "dependencies": {
    "@cornerstonejs/core": "^4.22.13",
